# Optional: GitHub personal access token used by /api/github/* routes.
# Without a token the public REST API limits requests to 60/hour per IP.
# With a token the limit is much higher. Server-only — do NOT prefix with NEXT_PUBLIC_.
GITHUB_TOKEN=

# Optional override of the GitHub REST API version date sent in the
# X-GitHub-Api-Version header. Leave blank to use the built-in default.
GITHUB_API_VERSION=
