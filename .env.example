# Optional: GitHub personal access token used by /api/github/* routes when no
# OAuth session is present. Without any token the public REST API limits
# requests to 60/hour per IP. Server-only — do NOT prefix with NEXT_PUBLIC_.
GITHUB_TOKEN=

# Optional override of the GitHub REST API version date sent in the
# X-GitHub-Api-Version header. Leave blank to use the built-in default.
GITHUB_API_VERSION=

# --- GitHub OAuth App ---
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must match GITHUB_OAUTH_REDIRECT_URI exactly.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Used to encrypt/sign GitMetro auth cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET=
